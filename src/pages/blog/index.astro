---
import '../../../global.css';
import { getCollection } from 'astro:content';
import { portfolioContent } from '../../data/portfolio';

let allPosts = [];
try {
	allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
		(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
	);
} catch {
	allPosts = [];
}

const postsByProject = portfolioContent.projects.map((project) => ({
	project,
	posts: allPosts
		.filter((post) => post.data.projectKey === project.key)
		.sort((a, b) => a.data.part - b.data.part),
}));
---

<html lang="en" class="h-full scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>Blog · Aymen Abdulkerim</title>
		<meta name="description" content="Project devlogs, lessons learned, and technical notes by Aymen Abdulkerim." />
		<link rel="canonical" href="https://aymenabdulkerim.dev/blog" />
		<meta property="og:url" content="https://aymenabdulkerim.dev/blog" />
		<script is:inline>
			(() => {
				const storedTheme = localStorage.getItem('theme');
				const shouldUseDark = storedTheme ? storedTheme === 'dark' : true;
				document.documentElement.classList.toggle('dark', shouldUseDark);
			})();
		</script>
	</head>
	<body class="blog-copy min-h-screen bg-background text-foreground antialiased">
		<button id="theme-toggle" type="button" class="theme-toggle-fab" aria-label="Toggle theme">
			<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
			</svg>
			<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="4"></circle>
				<path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
			</svg>
		</button>
		<main class="mx-auto flex w-full max-w-6xl flex-col gap-8 px-5 py-8 sm:px-8 sm:py-12">
			<header class="site-topbar rounded-lg border border-border p-6">
				<p class="font-mono text-sm text-primary">$ ls blog/</p>
				<h1 class="mt-2 text-3xl font-semibold sm:text-4xl">Project Devlog</h1>
				<p class="mt-3 text-base leading-7 text-muted-foreground sm:text-lg">
					Writing the journey behind each project in parts — what I learned, what broke, how I fixed it, and what I’d do better next.
				</p>
				<div class="mt-4 flex flex-wrap gap-2 text-sm">
					<a href="/" class="rounded-md border border-border bg-background px-3 py-2 hover:bg-muted">Back to portfolio</a>
				</div>
			</header>

			<section class="space-y-4">
				{
					postsByProject.map(({ project, posts }) => (
						<article class="rounded-lg border border-border bg-card p-5">
							<div class="mb-4 flex flex-wrap items-center justify-between gap-2">
								<div>
									<h2 class="text-xl font-semibold">{project.title}</h2>
									<p class="text-xs text-muted-foreground">{posts.length} parts</p>
								</div>
								<a
									href={`/blog/project/${project.key}`}
									class="inline-flex items-center gap-1 rounded-md border border-border bg-background px-3 py-2 text-sm font-semibold text-primary transition hover:bg-muted"
								>
									View project feed
								</a>
							</div>
							{posts.length > 0 ? (
								<ul class="space-y-2">
									{posts.map((post) => (
										<li class="rounded-md border border-border bg-background p-3">
											<a href={`/blog/post/${post.id}`} class="font-semibold text-primary hover:underline">
												Part {post.data.part}: {post.data.title}
											</a>
											<p class="mt-1 text-sm text-muted-foreground">{post.data.description}</p>
										</li>
									))}
								</ul>
							) : (
								<p class="text-sm text-muted-foreground">No entries yet for this project.</p>
							)}
						</article>
					))
				}
			</section>
		</main>

		<script is:inline>
			(() => {
				const toggleButton = document.getElementById('theme-toggle');
				if (!toggleButton) return;

				toggleButton.addEventListener('click', () => {
					const html = document.documentElement;
					const isDark = html.classList.toggle('dark');
					localStorage.setItem('theme', isDark ? 'dark' : 'light');
				});
			})();
		</script>
	</body>
</html>
