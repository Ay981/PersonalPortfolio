---
import '../../../global.css';
import { getCollection, type CollectionEntry } from 'astro:content';
import { portfolioContent } from '../../data/portfolio';
import Analytics from '@vercel/analytics/astro';

let allPosts: CollectionEntry<'blog'>[] = [];
try {
	allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
		(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
	);
} catch {
	allPosts = [];
}

const postsByProject = portfolioContent.projects.map((project) => ({
	project,
	posts: allPosts
		.filter((post) => post.data.projectKey === project.key)
		.sort((a, b) => a.data.part - b.data.part),
}));
---

<html lang="en" class="h-full scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>Blog · Aymen Abdulkerim</title>
		<meta name="description" content="Project devlogs, lessons learned, and technical notes by Aymen Abdulkerim." />
		<link rel="canonical" href="https://aymenabdulkerim.dev/blog" />
		<meta property="og:url" content="https://aymenabdulkerim.dev/blog" />
		<Analytics />
		<script is:inline>
			(() => {
				const storedTheme = localStorage.getItem('theme');
					const shouldUseDark = storedTheme ? storedTheme === 'dark' : true;
				document.documentElement.classList.toggle('dark', shouldUseDark);
			})();
		</script>
	</head>
	<body class="blog-copy min-h-screen bg-background text-foreground antialiased">
		<button id="theme-toggle" type="button" class="theme-toggle-fab" aria-label="Toggle theme">
			<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
			</svg>
			<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="4"></circle>
				<path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
			</svg>
		</button>

		<nav class="site-topbar scroll-chrome scroll-chrome-nav w-full border-y border-border px-5 py-2 text-sm sm:px-8">
			<div class="nav-inner flex w-full flex-nowrap items-center justify-between gap-3 overflow-x-auto [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
				<div class="flex shrink-0 items-center gap-2">
					<a href="/" class="breadcrumb-chip"><span class="sm:hidden">~</span><span class="hidden sm:inline">Portfolio</span></a>
					<span class="text-muted-foreground/40">/</span>
					<span class="breadcrumb-chip breadcrumb-chip-active"><span class="sm:hidden">posts</span><span class="hidden sm:inline">All posts</span></span>
				</div>
				<p class="font-mono hidden shrink-0 rounded-md border border-border bg-card px-3 py-2 text-xs text-muted-foreground sm:block">~/blog</p>
			</div>
		</nav>

		<div class="blog-layout-wrapper">
			<aside class="blog-projects-floating scroll-chrome scroll-chrome-side" aria-label="Blog project navigation">
				<p class="blog-sidebar-heading">Projects</p>
				<ul class="blog-sidebar-list">
					{
						postsByProject.map(({ project, posts }) => (
							<li>
								<a href={`#project-${project.key}`} class="blog-sidebar-link" aria-label={`Jump to ${project.title}`}>
									<span class="blog-sidebar-link-meta">{posts.length} parts <span class="blog-sidebar-link-state">→</span></span>
									<span class="blog-sidebar-link-title">{project.title}</span>
								</a>
							</li>
						))
					}
				</ul>
			</aside>
			<div class="blog-content-area">
			<header class="blog-index-shell rounded-2xl border border-border p-6 sm:p-8">
				<div class="mt-5 space-y-3">
					<p class="font-mono text-sm text-primary">$ ls blog/</p>
					<h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Project devlog</h1>
					<p class="max-w-3xl text-base leading-7 text-muted-foreground sm:text-lg">
						A running log of how each project was built — decisions, tradeoffs, mistakes, and the pieces I’d change on the next pass.
					</p>
				</div>
				
			</header>

			<section class="space-y-4">
				{
					postsByProject.map(({ project, posts }) => (
						<article
							id={`project-${project.key}`}
							class="project-index-shell blog-project-anchor rounded-2xl border border-border bg-card p-5 sm:p-6"
							data-feed-card
							data-feed-url={`/blog/project/${project.key}`}
							tabindex="0"
							role="link"
							aria-label={`Open ${project.title} project feed`}
						>
							<div class="mb-4 flex flex-wrap items-start justify-between gap-4">
								<div class="space-y-2">
									<h2 class="text-xl font-semibold tracking-tight sm:text-2xl">{project.title}</h2>
									<p class="max-w-3xl text-sm leading-7 text-muted-foreground">{project.description}</p>
									<p class="text-xs uppercase tracking-[0.22em] text-muted-foreground">{posts.length} parts</p>
								</div>
								<span class="inline-flex items-center gap-1 rounded-md border border-border bg-background px-3 py-2 text-xs font-semibold uppercase tracking-[0.22em] text-primary transition">
									View project feed
								</span>
							</div>
							{posts.length > 0 ? (
								<ul class="space-y-2">
									{posts.map((post, index) => {
										const isFuture = post.data.draft || post.data.pubDate > new Date();
										return (
											<li class:list={['rounded-lg border px-4 py-3 transition', isFuture ? 'border-border/50 bg-background/40 opacity-50' : 'border-border bg-background']}>
												<div class="flex flex-wrap items-start justify-between gap-3">
													<div class="space-y-1">
														<p class="text-[10px] uppercase tracking-[0.24em] text-muted-foreground">Part {String(post.data.part).padStart(2, '0')}</p>
														{isFuture ? (
															<span class="block text-sm font-semibold tracking-tight text-foreground/75 sm:text-base">{post.data.title}</span>
														) : (
															<a href={`/blog/post/${post.id}`} class="block text-sm font-semibold tracking-tight text-foreground transition hover:text-primary sm:text-base">
																{post.data.title}
															</a>
														)}
													</div>
													<span class:list={['inline-flex items-center rounded-md border px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.2em]', isFuture ? 'border-border/50 text-muted-foreground' : index === 0 ? 'border-success/40 bg-success/10 text-success' : 'border-primary/30 bg-primary/10 text-primary']}>
														{isFuture ? 'Future' : index === 0 ? 'Live' : 'Published'}
													</span>
												</div>
												<p class="mt-2 max-w-3xl text-sm leading-6 text-muted-foreground">{post.data.description}</p>
											</li>
										);
									})}
								</ul>
							) : (
								<p class="text-sm text-muted-foreground">No entries yet for this project.</p>
							)}
						</article>
					))
				}
			</section>
		</div>
		</div>

		<script is:inline>
			(() => {
				const toggleButton = document.getElementById('theme-toggle');
				if (!toggleButton) return;

				toggleButton.addEventListener('click', () => {
					const html = document.documentElement;
					const isDark = html.classList.toggle('dark');
					localStorage.setItem('theme', isDark ? 'dark' : 'light');
				});

					const feedCards = Array.from(document.querySelectorAll('[data-feed-card]'));
					feedCards.forEach((card) => {
						const feedUrl = card.getAttribute('data-feed-url');
						if (!feedUrl) return;

						card.addEventListener('click', (event) => {
							const target = event.target instanceof Element ? event.target : null;
							if (target?.closest('a, button, [data-no-feed]')) return;
							window.location.href = feedUrl;
						});

						card.addEventListener('keydown', (event) => {
							if (event.key !== 'Enter' && event.key !== ' ') return;
							window.location.href = feedUrl;
						});
					});

				let previousY = window.scrollY;
				let rafId = 0;
				const hiddenClass = 'chrome-hidden';

				const updateChromeVisibility = () => {
					rafId = 0;
					const currentY = window.scrollY;
					const delta = currentY - previousY;

					if (currentY <= 72) {
						document.body.classList.remove(hiddenClass);
					} else if (delta > 6) {
						document.body.classList.add(hiddenClass);
					} else if (delta < -6) {
						document.body.classList.remove(hiddenClass);
					}

					previousY = currentY;
				};

				window.addEventListener(
					'scroll',
					() => {
						if (rafId) return;
						rafId = window.requestAnimationFrame(updateChromeVisibility);
					},
					{ passive: true }
				);
			})();
		</script>
	</body>
</html>

<style>
	:root {
		--page-max: 1400px;
		--side-col: 220px;
	}

	.nav-inner {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 48px;
	}

	.scroll-chrome {
		transition: transform 220ms ease, opacity 220ms ease;
		will-change: transform, opacity;
	}

	.scroll-chrome-nav {
		position: sticky;
		top: 0;
		z-index: 45;
		background: color-mix(in oklab, var(--background) 92%, transparent);
		backdrop-filter: blur(6px);
	}

	body.chrome-hidden .scroll-chrome-nav {
		transform: translateY(calc(-100% - 2px));
	}

	.blog-layout-wrapper {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 48px;
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
	}

	.blog-projects-floating {
		display: none;
	}

	.blog-sidebar-heading {
		margin: 0 0 28px;
		padding: 0 0 24px;
		border-bottom: 1px solid var(--border);
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
		font-size: 9.5px;
		letter-spacing: 0.18em;
		color: var(--muted-foreground);
		text-transform: uppercase;
	}

	.blog-sidebar-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.blog-sidebar-link {
		display: block;
		padding: 16px 0;
		border-top: 1px solid var(--border);
		text-decoration: none;
		color: inherit;
	}

	.blog-sidebar-link:last-child {
		border-bottom: 1px solid var(--border);
	}

	.blog-sidebar-link-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 6px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
		font-size: 9.5px;
		letter-spacing: 0.14em;
		color: var(--muted-foreground);
		text-transform: uppercase;
	}

	.blog-sidebar-link-title {
		font-size: 13.5px;
		line-height: 1.5;
		font-weight: 400;
	}

	.blog-sidebar-link-state {
		font-size: 11px;
		color: var(--primary);
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
	}

	.blog-sidebar-link:hover .blog-sidebar-link-title {
		color: var(--primary);
	}

	.blog-content-area {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		width: 100%;
		padding: 40px 0 80px;
	}

	@media (min-width: 1280px) {
		.blog-layout-wrapper {
			grid-template-columns: var(--side-col) minmax(0, 1fr);
		}

		.blog-projects-floating {
			display: block;
			position: sticky;
			top: 56px;
			padding: 64px 40px 64px 0;
			border-right: 1px solid var(--border);
			min-height: calc(100vh - 56px);
			overflow-y: auto;
		}

		body.chrome-hidden .scroll-chrome-side {
			opacity: 0;
			transform: translateY(-18px);
			pointer-events: none;
		}

		.blog-content-area {
			padding: 64px 0 120px 32px;
		}
	}

	@media (max-width: 800px) {
		.nav-inner {
			padding: 0 24px;
		}

		.blog-layout-wrapper {
			padding: 0 24px;
		}

		.blog-content-area {
			padding: 40px 0 80px;
		}
	}
</style>
