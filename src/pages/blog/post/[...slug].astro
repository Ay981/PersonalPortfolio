---
import '../../../../global.css';
import { getCollection, render } from 'astro:content';
import Analytics from '@vercel/analytics/astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);

const projectPosts = (await getCollection('blog', ({ data }) => data.projectKey === post.data.projectKey)).sort(
	(a, b) => a.data.part - b.data.part
);

const currentIndex = projectPosts.findIndex((entry) => entry.id === post.id);
const nextPost = currentIndex >= 0 ? projectPosts[currentIndex + 1] : undefined;
---

<html lang="en" class="h-full scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>{post.data.title} · Blog</title>
		<meta name="description" content={post.data.description} />
		<link rel="canonical" href={`https://aymenabdulkerim.dev/blog/post/${post.id}/`} />
		<meta property="og:url" content={`https://aymenabdulkerim.dev/blog/post/${post.id}/`} />
		<Analytics />
		<script is:inline>
			(() => {
				const storedTheme = localStorage.getItem('theme');
				const shouldUseDark = storedTheme ? storedTheme === 'dark' : true;
				document.documentElement.classList.toggle('dark', shouldUseDark);
			})();
		</script>
		<style>
			:root {
				--page-max: 1400px;
				--side-col: 220px;
				--content-col: 750px;
			}

			.nav-inner,
			.page-wrapper {
				max-width: var(--page-max);
				margin: 0 auto;
				padding: 0 48px;
			}

			.scroll-chrome {
				transition: transform 220ms ease, opacity 220ms ease;
				will-change: transform, opacity;
			}

			.scroll-chrome-nav {
				position: sticky;
				top: 0;
				z-index: 45;
				background: color-mix(in oklab, var(--background) 92%, transparent);
				backdrop-filter: blur(6px);
			}

			body.chrome-hidden .scroll-chrome-nav {
				transform: translateY(calc(-100% - 2px));
			}

			.page-wrapper {
				display: flex;
				width: 100%;
			}

			.post-layout-shell {
				display: grid;
				grid-template-columns: 1fr;
				width: 100%;
				gap: 0;
			}

			.series-sidebar {
				display: none;
			}

			.post-main-stack {
				display: flex;
				flex-direction: column;
				gap: 0;
				width: 100%;
				padding: 40px 0 80px 32px;
			}

			.post-header {
				padding: 0 0 56px;
				border-bottom: 1px solid var(--border);
				margin-bottom: 56px;
				max-width: 85%;
			}

			.post-kicker {
				position: relative;
				padding-left: 1.25rem;
				margin-bottom: 20px;
			}

			.post-kicker::before {
				content: '';
				position: absolute;
				left: 0;
				top: 50%;
				width: 0.85rem;
				height: 1px;
				background: var(--primary);
				transform: translateY(-50%);
			}

			.post-lede,
			.content-measure,
			.next-part-shell,
			.article-footer {
				max-width: none;
			}

			.article-shell {
				position: relative;
				overflow: visible;
				padding: 0 0 48px;
				margin-bottom: 56px;
				border-bottom: 1px solid var(--border);
				max-width: none;
			}

			.next-part-shell {
				padding: 0 0 40px;
				margin-top: 8px;
				border-bottom: 1px solid var(--border);
			}

			.article-footer {
				padding-top: 40px;
				margin-top: 16px;
			}

			.prose-shell :global(h2) {
				margin-top: 0;
				margin-bottom: 16px;
				font-size: 9.5px;
				font-weight: 600;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--primary);
				display: flex;
				align-items: center;
				gap: 12px;
			}

			.prose-shell :global(h2)::after {
				content: '';
				flex: 1;
				height: 1px;
				background: color-mix(in oklab, var(--primary) 16%, transparent);
				max-width: 40px;
			}

			.prose-shell :global(p),
			.prose-shell :global(li) {
				line-height: 1.75;
				color: color-mix(in oklab, var(--foreground) 88%, var(--muted-foreground));
				font-size: 17px;
				margin-bottom: 20px;
			}

			.prose-shell :global(ul),
			.prose-shell :global(ol) {
				padding-left: 1.25rem;
				margin-bottom: 20px;
			}

			.prose-shell :global(code) {
				border: 1px solid var(--border);
				border-radius: 0.4rem;
				background: color-mix(in oklab, var(--muted) 70%, transparent);
				padding: 0.15rem 0.4rem;
				font-size: 0.85rem;
			}

			.prose-shell :global(pre) {
				overflow-x: auto;
				border: 1px solid var(--border);
				border-radius: 0.55rem;
				background: color-mix(in oklab, var(--background) 72%, black 28%);
				padding: 0.85rem 1rem;
				box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--primary) 22%, transparent);
				margin: 32px 0;
			}

			:global(.dark) .prose-shell :global(pre) {
				background: color-mix(in oklab, var(--background) 78%, black 22%);
			}

			.prose-shell :global(pre code) {
				border: none;
				background: transparent;
				padding: 0;
			}

			.prose-shell :global(a) {
				color: var(--primary);
				text-decoration: underline;
				text-underline-offset: 2px;
			}

			.breadcrumb-chip {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				border: 1px solid transparent;
				padding: 0.4rem 0.7rem;
				border-radius: 999px;
				transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
			}

			.breadcrumb-chip:hover {
				color: var(--foreground);
				border-color: var(--border);
				background: color-mix(in oklab, var(--background) 70%, transparent);
			}

			.breadcrumb-chip-active {
				color: var(--foreground);
				border-color: var(--border);
				background: color-mix(in oklab, var(--background) 70%, transparent);
			}

			@media (min-width: 1280px) {
				.post-layout-shell {
					grid-template-columns: var(--side-col) minmax(0, 1fr);
				}

				.series-sidebar {
					display: block;
					position: sticky;
					top: 56px;
					padding: 64px 40px 64px 0;
					border-right: 1px solid var(--border);
					min-height: calc(100vh - 56px);
					overflow-y: auto;
				}

				body.chrome-hidden .scroll-chrome-side {
					opacity: 0;
					transform: translateY(-18px);
					pointer-events: none;
				}

				.series-sidebar-heading {
					margin: 0 0 28px;
					padding: 0 0 24px;
					border-bottom: 1px solid var(--border);
					font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
					font-size: 9.5px;
					letter-spacing: 0.18em;
					color: var(--muted-foreground);
					text-transform: uppercase;
				}

				.series-sidebar-list {
					list-style: none;
					margin: 0;
					padding: 0;
				}

				.series-sidebar-link {
					display: block;
					padding: 16px 0;
					border-top: 1px solid var(--border);
					text-decoration: none;
					color: inherit;
				}

				.series-sidebar-link:last-child {
					border-bottom: 1px solid var(--border);
				}

				.series-sidebar-link-meta {
					display: flex;
					align-items: center;
					justify-content: space-between;
					margin-bottom: 6px;
					font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
					font-size: 9.5px;
					letter-spacing: 0.14em;
					color: var(--muted-foreground);
					text-transform: uppercase;
				}

				.series-sidebar-link-title {
					font-size: 13.5px;
					line-height: 1.5;
					font-weight: 400;
				}

				.series-sidebar-link-state {
					font-size: 11px;
					color: var(--primary);
					font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
				}

				.series-sidebar-link-state.is-current {
					background: var(--primary);
					color: white;
					padding: 2px 7px;
					border-radius: 2px;
					font-size: 8.5px;
					letter-spacing: 0.1em;
					font-weight: 500;
				}

				.series-sidebar-link:hover .series-sidebar-link-title {
					color: var(--primary);
				}

				.post-main-stack {
					padding: 64px 0 120px 32px;
				}

				.post-header,
				.article-shell,
				.post-lede,
				.content-measure,
				.next-part-shell,
				.article-footer {
					max-width: 900px;
					padding-right: 64px;
				}
			}

			@media (max-width: 800px) {
				.nav-inner,
				.page-wrapper {
					padding: 0 24px;
				}

				.post-main-stack {
					padding: 40px 0 80px;
				}

				.post-header {
					padding: 0 0 32px;
					margin-bottom: 40px;
				}

				.article-shell,
				.next-part-shell,
				.article-footer,
				.post-header,
				.content-measure,
				.post-lede {
					max-width: none;
				}
			}
		</style>
	</head>
	<body class="blog-copy min-h-screen w-full bg-background text-foreground antialiased">
		<button id="theme-toggle" type="button" class="theme-toggle-fab" aria-label="Toggle theme">
			<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
			</svg>
			<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="4"></circle>
				<path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
			</svg>
		</button>

		<nav class="site-topbar scroll-chrome scroll-chrome-nav w-full border-y border-border px-5 py-2 text-sm sm:px-8">
			<div class="nav-inner flex w-full flex-nowrap items-center justify-between gap-3 overflow-x-auto [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
				<div class="flex shrink-0 items-center gap-2">
					<a href="/" class="breadcrumb-chip"><span class="sm:hidden">~</span><span class="hidden sm:inline">Portfolio</span></a>
					<span class="text-muted-foreground/40">/</span>
					<a href="/blog" class="breadcrumb-chip"><span class="sm:hidden">posts</span><span class="hidden sm:inline">All posts</span></a>
					<span class="text-muted-foreground/40">/</span>
					<a href={`/blog/project/${post.data.projectKey}`} class="breadcrumb-chip"><span class="sm:hidden">../{post.data.projectKey}</span><span class="hidden sm:inline">{post.data.projectName}</span></a>
					<span class="text-muted-foreground/40">/</span>
					<span class="breadcrumb-chip breadcrumb-chip-active"><span class="sm:hidden">P{post.data.part}</span><span class="hidden sm:inline">Part {post.data.part}</span></span>
				</div>
				<p class="font-mono hidden shrink-0 rounded-md border border-border bg-card px-3 py-2 text-xs text-muted-foreground sm:block">~/blog/post/{post.id}</p>
			</div>
		</nav>

		<main class="page-wrapper">
			<section class="post-layout-shell">
				<aside class="series-sidebar scroll-chrome scroll-chrome-side" aria-label="Series parts navigation">
					<p class="series-sidebar-heading">Series parts</p>
					<ul class="series-sidebar-list">
						{
							projectPosts.map((entry) => {
								const isCurrent = entry.id === post.id;
								return (
									<li>
										<a href={`/blog/post/${entry.id}/`} aria-current={isCurrent ? 'page' : undefined} class="series-sidebar-link">
											<span class="series-sidebar-link-meta">Part {String(entry.data.part).padStart(2, '0')}<span class:list={["series-sidebar-link-state", isCurrent ? 'is-current' : '']}>{isCurrent ? 'Now' : '→'}</span></span>
											<span class="series-sidebar-link-title">{entry.data.title}</span>
										</a>
									</li>
								);
							})
						}
					</ul>
				</aside>

				<div class="post-main-stack">
					<header class="post-header">
						<p class="post-kicker font-mono text-xs uppercase tracking-[0.32em] text-primary sm:text-sm">{post.data.projectName} · Part {post.data.part}</p>
						<h1 class="mt-3 max-w-5xl text-balance text-4xl font-black tracking-[-0.05em] text-foreground sm:text-6xl lg:text-7xl lg:leading-[0.92]">{post.data.title}</h1>
						<p class="mt-3 flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.24em] text-muted-foreground sm:text-sm">
							<span>Published {post.data.pubDate.toLocaleDateString()}</span>
							<span class="hidden sm:inline text-muted-foreground/40">|</span>
							<span class="text-primary/80">Deep dive</span>
						</p>
						<p class="post-lede mt-5 text-lg italic leading-[1.8] text-foreground/88 sm:text-xl lg:text-[1.4rem]">{post.data.description}</p>
						{post.data.tags.length > 0 && (
							<ul class="mt-6 flex flex-wrap gap-2">
								{post.data.tags.map((tag) => <li class="rounded-sm border border-border/70 px-2 py-1 text-[10px] font-mono uppercase tracking-[0.18em] text-muted-foreground">{tag}</li>)}
							</ul>
						)}
					</header>

					<article class="article-shell">
						<div class="content-measure prose-shell">
							<Content />
						</div>
					</article>

					{nextPost && (
						<section class="next-part-shell">
							<p class="text-xs uppercase tracking-[0.28em] text-muted-foreground">Up next · Part {String(nextPost.data.part).padStart(2, '0')}</p>
							<div class="mt-3 flex flex-wrap items-start justify-between gap-4">
								<div class="space-y-2">
									<h2 class="text-xl font-semibold text-foreground/80">{nextPost.data.title}</h2>
									<p class="max-w-3xl text-sm leading-7 text-muted-foreground">{nextPost.data.description}</p>
								</div>
								<div class="flex shrink-0 flex-col items-end gap-2 text-right">
									<span class:list={[
										'inline-flex items-center rounded-md border px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em]',
										nextPost.data.pubDate > new Date() ? 'border-border/50 text-muted-foreground' : 'border-primary/30 bg-primary/10 text-primary',
									]}>
										{nextPost.data.pubDate > new Date() ? 'Not published yet' : 'Published'}
									</span>
									<a href={`/blog/project/${post.data.projectKey}`} class="inline-flex items-center gap-1 text-sm font-semibold text-primary transition hover:underline">
										Go to series
									</a>
								</div>
							</div>
						</section>
					)}

					<footer class="article-footer flex flex-wrap items-center justify-between gap-3 border-t border-border text-xs uppercase tracking-[0.28em] text-muted-foreground">
						<a href={`/blog/project/${post.data.projectKey}`} class="transition hover:text-primary">← Back to {post.data.projectName}</a>
						<span>Part {post.data.part} of {projectPosts.length}</span>
					</footer>
				</div>
			</section>
		</main>

		<script is:inline>
			(() => {
				const toggleButton = document.getElementById('theme-toggle');
				if (!toggleButton) return;

				toggleButton.addEventListener('click', () => {
					const html = document.documentElement;
					const isDark = html.classList.toggle('dark');
					localStorage.setItem('theme', isDark ? 'dark' : 'light');
				});

				let previousY = window.scrollY;
				let rafId = 0;
				const hiddenClass = 'chrome-hidden';

				const updateChromeVisibility = () => {
					rafId = 0;
					const currentY = window.scrollY;
					const delta = currentY - previousY;

					if (currentY <= 72) {
						document.body.classList.remove(hiddenClass);
					} else if (delta > 6) {
						document.body.classList.add(hiddenClass);
					} else if (delta < -6) {
						document.body.classList.remove(hiddenClass);
					}

					previousY = currentY;
				};

				window.addEventListener(
					'scroll',
					() => {
						if (rafId) return;
						rafId = window.requestAnimationFrame(updateChromeVisibility);
					},
					{ passive: true }
				);
			})();
		</script>
	</body>
</html>
