---
import '../../global.css';
import { getCollection } from 'astro:content';
import { portfolioContent } from '../data/portfolio';

const { name, role, bio, skills, projects, email, github, linkedin, upwork } = portfolioContent;
const blogPosts = await getCollection('blog', ({ data }) => !data.draft);
const blogPostCountByProject = blogPosts.reduce(
	(accumulator, post) => {
		accumulator[post.data.projectKey] = (accumulator[post.data.projectKey] ?? 0) + 1;
		return accumulator;
	},
	{} as Record<string, number>
);

const sections = [
	{ id: 'hero', label: 'Hero' },
	{ id: 'about', label: 'About' },
	{ id: 'projects', label: 'Projects' },
	{ id: 'blog', label: 'Blog' },
	{ id: 'skills', label: 'Skills' },
	{ id: 'contact', label: 'Contact' },
];
---

<html lang="en" class="h-full scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{name} · Portfolio</title>
		<meta name="description" content={`${name} portfolio - ${role}`} />
		<script is:inline>
			(() => {
				const storedTheme = localStorage.getItem('theme');
				const shouldUseDark = storedTheme ? storedTheme === 'dark' : true;

				document.documentElement.classList.toggle('dark', shouldUseDark);
			})();
		</script>
	</head>
	<body class="h-full antialiased">
		<button id="theme-toggle" type="button" class="theme-toggle-fab" aria-label="Toggle theme">
			<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
			</svg>
			<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="4"></circle>
				<path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
			</svg>
		</button>
		<main class="flex min-h-screen w-full flex-col gap-7 py-6 sm:py-8">
			<header class="sticky top-0 z-30 border-y-2 border-border bg-background/95 px-4 py-3 backdrop-blur sm:px-6">
				<div class="flex flex-wrap items-center justify-between gap-3 text-sm">
					<p class="text-muted-foreground">~/home/{name.toLowerCase().replace(' ', '')}/portfolio</p>
				</div>
				<nav aria-label="Section navigation" class="mt-3 border-t border-border pt-3">
					<ul class="flex flex-wrap gap-2 text-sm">
						{
							sections.map((section) => (
								<li>
									<a
										href={`#${section.id}`}
										data-nav-link
										data-section-id={section.id}
										class="block rounded-md border-2 border-border bg-background px-3 py-1.5 transition hover:bg-muted"
									>
										{section.label}
									</a>
								</li>
							))
						}
					</ul>
				</nav>
			</header>

			<div class="mx-auto flex w-full max-w-400 flex-col gap-7 px-4 sm:px-6">

			<section id="hero" class="scroll-mt-28 space-y-4 rounded-lg border-2 border-border bg-card p-6">
				<p class="text-sm text-muted-foreground"><span class="mr-2 font-bold text-success">$</span>whoami</p>
				<h1 class="text-4xl font-bold tracking-tight sm:text-6xl">
					{name}<span aria-hidden="true" class="blink-cursor text-primary">▌</span>
				</h1>
				<p class="text-sm font-semibold uppercase tracking-[0.22em] text-primary sm:text-base">
					<span class="typing-line">{role}</span>
				</p>
				<p class="max-w-3xl text-base leading-7 text-foreground">
					I build <span class="font-semibold text-primary">full-stack products</span> that feel human to use, from clean
					frontend experiences to reliable backend systems. I enjoy shipping practical software with
					<span class="font-semibold text-primary"> React</span>,
					<span class="font-semibold text-primary"> Next.js</span>,
					<span class="font-semibold text-primary"> Laravel</span>, and modern web tooling.
				</p>
				<div class="flex flex-wrap gap-3 pt-2 text-sm">
					<a
						class="rounded-md border-2 border-primary bg-primary px-3 py-2 font-semibold text-primary-foreground transition hover:brightness-110"
						href={github}
						target="_blank"
						rel="noreferrer"
					>
						GitHub
					</a>
					<a
						class="rounded-md border-2 border-border px-3 py-2 hover:bg-muted"
						href={linkedin}
						target="_blank"
						rel="noreferrer"
					>
						LinkedIn
					</a>
					<a class="rounded-md border-2 border-border px-3 py-2 hover:bg-muted" href={upwork} target="_blank" rel="noreferrer">
						Upwork
					</a>
					<a class="rounded-md border-2 border-border px-3 py-2 hover:bg-muted" href={`mailto:${email}`}>Email</a>
				</div>
			</section>

			<section id="about" class="scroll-mt-28 space-y-3 rounded-lg border-2 border-border bg-card p-6">
				<h2 class="text-lg font-semibold uppercase tracking-[0.15em] text-primary">01 · About</h2>
				<p class="leading-7 text-muted-foreground">
					I focus on building useful software end-to-end: product UI, API design, and practical deployment workflows.
					My approach is straightforward — readable code, strong UX, and features that solve real user problems.
				</p>
			</section>

			<section id="projects" class="scroll-mt-28 space-y-4 rounded-lg border-2 border-border bg-card p-6">
				<h2 class="text-lg font-semibold uppercase tracking-[0.15em] text-primary">02 · Projects</h2>
				<div class="grid gap-4 md:grid-cols-2">
					{
						projects.map((project) => (
							<article class="rounded-md border-2 border-border bg-background p-4">
								<div class="mb-4 overflow-hidden rounded-md border border-border bg-muted">
									<img
										src={project.screenshotUrl}
										alt={`${project.title} project screenshot`}
										loading="lazy"
										decoding="async"
										class="h-48 w-full object-cover sm:h-64 md:h-80 lg:h-96"
									/>
								</div>
								<div class="mb-2 flex items-center justify-between gap-3">
									<h3 class="font-semibold">{project.title}</h3>
									<a href={project.url} target="_blank" rel="noreferrer" class="text-sm text-primary hover:underline">
										View
									</a>
								</div>
								<p class="text-sm leading-6 text-foreground">{project.description}</p>
								<ul class="mt-3 flex flex-wrap gap-2">
									{project.tech.map((item) => <li class="rounded border border-border px-2 py-1 text-xs text-primary">{item}</li>)}
								</ul>
								<div class="mt-4 flex items-center justify-between gap-3 border-t border-border pt-3 text-xs text-muted-foreground">
									<span>{blogPostCountByProject[project.key] ?? 0} devlog part(s)</span>
									<a href={`/blog/project/${project.key}`} class="text-primary hover:underline">
										Read devlog
									</a>
								</div>
							</article>
						))
					}
				</div>
			</section>

			<section id="blog" class="scroll-mt-28 space-y-4 rounded-lg border-2 border-border bg-card p-6">
				<h2 class="text-lg font-semibold uppercase tracking-[0.15em] text-primary">03 · Blog</h2>
				<p class="text-sm leading-6 text-muted-foreground">
					Writing build logs by project: lessons learned, implementation notes, snippets, and architecture decisions.
				</p>
				<a href="/blog" class="inline-block rounded-md border-2 border-border bg-background px-3 py-2 text-sm hover:bg-muted">
					Open all posts
				</a>
			</section>

			<section id="skills" class="scroll-mt-28 space-y-4 rounded-lg border-2 border-border bg-card p-6">
				<h2 class="text-lg font-semibold uppercase tracking-[0.15em] text-primary">04 · Skills</h2>
				<ul class="flex flex-wrap gap-2">
					{skills.map((skill) => <li class="rounded-md border-2 border-border bg-background px-3 py-2 text-sm">{skill}</li>)}
				</ul>
			</section>

			<section id="contact" class="scroll-mt-28 space-y-4 rounded-lg border-2 border-border bg-card p-6">
				<h2 class="text-lg font-semibold uppercase tracking-[0.15em] text-primary">05 · Contact</h2>
				<p class="text-muted-foreground">Open to collaboration, freelance opportunities, and product-focused development work.</p>
				<div class="flex flex-wrap gap-3 text-sm">
					<a class="rounded-md border-2 border-border px-3 py-2 hover:bg-muted" href={`mailto:${email}`}>{email}</a>
					<a class="rounded-md border-2 border-border px-3 py-2 hover:bg-muted" href={github} target="_blank" rel="noreferrer">
						GitHub Profile
					</a>
					<a
						class="rounded-md border-2 border-border px-3 py-2 hover:bg-muted"
						href={linkedin}
						target="_blank"
						rel="noreferrer"
					>
						LinkedIn Profile
					</a>
					<a class="rounded-md border-2 border-border px-3 py-2 hover:bg-muted" href={upwork} target="_blank" rel="noreferrer">
						Upwork Profile
					</a>
				</div>
			</section>
			</div>
		</main>

		<script is:inline>
			(() => {
				const toggleButton = document.getElementById('theme-toggle');
				if (toggleButton) {
					toggleButton.addEventListener('click', () => {
						const html = document.documentElement;
						const isDark = html.classList.toggle('dark');
						localStorage.setItem('theme', isDark ? 'dark' : 'light');
					});
				}

				const navLinks = Array.from(document.querySelectorAll('[data-nav-link]'));
				const sections = navLinks
					.map((link) => {
						const sectionId = link.getAttribute('data-section-id');
						if (!sectionId) return null;
						const sectionElement = document.getElementById(sectionId);
						if (!sectionElement) return null;
						return { sectionId, sectionElement };
					})
					.filter((entry) => entry !== null);

				if (navLinks.length === 0 || sections.length === 0) return;

				const setActiveLink = (activeId) => {
					navLinks.forEach((link) => {
						const isActive = link.getAttribute('data-section-id') === activeId;
						link.classList.toggle('bg-muted', isActive);
						link.classList.toggle('text-primary', isActive);
						link.setAttribute('aria-current', isActive ? 'page' : 'false');
					});
				};

				const observer = new IntersectionObserver(
					(entries) => {
						const visibleEntries = entries
							.filter((entry) => entry.isIntersecting)
							.sort((entryA, entryB) => entryB.intersectionRatio - entryA.intersectionRatio);

						if (visibleEntries.length === 0) return;
						setActiveLink(visibleEntries[0].target.id);
					},
					{
						rootMargin: '-35% 0px -50% 0px',
						threshold: [0.2, 0.4, 0.6],
					}
				);

				sections.forEach(({ sectionElement }) => observer.observe(sectionElement));
				setActiveLink(sections[0].sectionId);
			})();
		</script>

		<style>
			.blink-cursor {
				animation: blink-caret 1.1s steps(1, end) infinite;
			}

			.typing-line {
				display: inline-block;
				max-width: 0;
				overflow: hidden;
				white-space: nowrap;
				animation: typing 2.2s steps(20, end) 0.2s forwards;
			}

			@keyframes blink-caret {
				0%,
				49% {
					opacity: 1;
				}
				50%,
				100% {
					opacity: 0;
				}
			}

			@keyframes typing {
				from {
					max-width: 0;
				}
				to {
					max-width: 24ch;
				}
			}
		</style>
	</body>
</html>
