---
import '../../../../global.css';
import { getCollection } from 'astro:content';
import { portfolioContent } from '../../../data/portfolio';

export async function getStaticPaths() {
	return portfolioContent.projects.map((projectItem) => ({
		params: { project: projectItem.key },
	}));
}

const projectKey = Astro.params.project ?? '';
const project = portfolioContent.projects.find((item) => item.key === projectKey);

let projectPosts = [];
try {
	projectPosts = (await getCollection('blog', ({ data }) => !data.draft && data.projectKey === projectKey)).sort(
		(a, b) => a.data.part - b.data.part
	);
} catch {
	projectPosts = [];
}

if (!project) {
	return Astro.redirect('/blog');
}
---

<html lang="en" class="h-full scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>{project.title} · Devlog</title>
		<meta name="description" content={`All devlog entries for ${project.title}.`} />
		<link rel="canonical" href={`https://aymenabdulkerim.dev/blog/project/${project.key}/`} />
		<meta property="og:url" content={`https://aymenabdulkerim.dev/blog/project/${project.key}/`} />
		<script is:inline>
			(() => {
				const storedTheme = localStorage.getItem('theme');
				const shouldUseDark = storedTheme ? storedTheme === 'dark' : true;
				document.documentElement.classList.toggle('dark', shouldUseDark);
			})();
		</script>
	</head>
	<body class="blog-copy min-h-screen bg-background text-foreground antialiased">
		<button id="theme-toggle" type="button" class="theme-toggle-fab" aria-label="Toggle theme">
			<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
			</svg>
			<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="4"></circle>
				<path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
			</svg>
		</button>
		<main class="mx-auto flex w-full max-w-5xl flex-col gap-6 px-5 py-8 sm:px-8 sm:py-12">
			<nav class="site-topbar flex flex-wrap gap-2 rounded-md border border-border p-2 text-sm">
				<a href="/" class="rounded-md border border-border bg-card px-3 py-2 hover:bg-muted">Portfolio</a>
				<a href="/blog" class="rounded-md border border-border bg-card px-3 py-2 hover:bg-muted">All posts</a>
			</nav>

			<header class="site-topbar rounded-lg border border-border p-6">
				<p class="font-mono text-sm text-primary">$ tree blog/{project.key}</p>
				<h1 class="mt-2 text-3xl font-semibold sm:text-4xl">{project.title} Devlog</h1>
				<p class="mt-3 text-base leading-7 text-muted-foreground">{project.description}</p>
			</header>

			<section class="space-y-3">
				{projectPosts.map((post) => (
					<article class="rounded-lg border border-border bg-card p-5">
						<div class="flex flex-wrap items-center justify-between gap-2">
							<p class="font-mono text-sm text-primary">Part {post.data.part}</p>
							<p class="text-xs text-muted-foreground">{post.data.pubDate.toLocaleDateString()}</p>
						</div>
						<h2 class="mt-1 text-xl font-semibold">{post.data.title}</h2>
						<p class="mt-2 text-base leading-7 text-muted-foreground">{post.data.description}</p>
						<a href={`/blog/post/${post.id}`} class="mt-3 inline-flex items-center gap-1 rounded-md border border-border bg-background px-3 py-2 text-sm font-semibold text-primary hover:bg-muted">
							Read part {post.data.part}
						</a>
					</article>
				))}
			</section>
		</main>

		<script is:inline>
			(() => {
				const toggleButton = document.getElementById('theme-toggle');
				if (!toggleButton) return;

				toggleButton.addEventListener('click', () => {
					const html = document.documentElement;
					const isDark = html.classList.toggle('dark');
					localStorage.setItem('theme', isDark ? 'dark' : 'light');
				});
			})();
		</script>
	</body>
</html>
