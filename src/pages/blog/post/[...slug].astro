---
import '../../../../global.css';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);

const projectPosts = (await getCollection('blog', ({ data }) => data.projectKey === post.data.projectKey)).sort(
	(a, b) => a.data.part - b.data.part
);

const currentIndex = projectPosts.findIndex((entry) => entry.id === post.id);
const nextPost = currentIndex >= 0 ? projectPosts[currentIndex + 1] : undefined;
---

<html lang="en" class="h-full scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>{post.data.title} · Blog</title>
		<meta name="description" content={post.data.description} />
		<link rel="canonical" href={`https://aymenabdulkerim.dev/blog/post/${post.id}/`} />
		<meta property="og:url" content={`https://aymenabdulkerim.dev/blog/post/${post.id}/`} />
		<script is:inline>
			(() => {
				const storedTheme = localStorage.getItem('theme');
					const shouldUseDark = storedTheme ? storedTheme === 'dark' : true;
				document.documentElement.classList.toggle('dark', shouldUseDark);
			})();
		</script>
	</head>
	<body class="blog-copy min-h-screen w-full bg-background text-foreground antialiased">
		<button id="theme-toggle" type="button" class="theme-toggle-fab" aria-label="Toggle theme">
			<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
			</svg>
			<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="4"></circle>
				<path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
			</svg>
		</button>
		<main class="mx-auto flex w-full max-w-6xl flex-col gap-6 px-5 py-8 sm:px-8 sm:py-12">
			<nav class="site-topbar flex flex-nowrap items-center justify-between gap-3 overflow-x-auto rounded-md border border-border p-2 text-sm [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
				<div class="flex shrink-0 items-center gap-2">
					<a href="/" class="breadcrumb-chip">Portfolio</a>
					<span class="text-muted-foreground/40">/</span>
					<a href="/blog" class="breadcrumb-chip">All posts</a>
					<span class="text-muted-foreground/40">/</span>
					<a href={`/blog/project/${post.data.projectKey}`} class="breadcrumb-chip">{post.data.projectName}</a>
					<span class="text-muted-foreground/40">/</span>
					<span class="breadcrumb-chip breadcrumb-chip-active">Part {post.data.part}</span>
				</div>
				<p class="font-mono shrink-0 rounded-md border border-border bg-card px-3 py-2 text-xs text-muted-foreground">~/blog/post/{post.id}</p>
			</nav>

			<header class="site-topbar rounded-lg border border-border p-6">
				<p class="font-mono text-sm text-muted-foreground"><span class="mr-2 font-bold text-success">$</span>{post.data.projectName} · Part {post.data.part}</p>
				<h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-5xl">{post.data.title}</h1>
				<p class="mt-2 text-sm text-muted-foreground">Published {post.data.pubDate.toLocaleDateString()}</p>
				<p class="mt-4 max-w-4xl text-base leading-7 text-foreground/95 sm:text-lg">{post.data.description}</p>
				{post.data.tags.length > 0 && (
					<ul class="mt-4 flex flex-wrap gap-2">
						{post.data.tags.map((tag) => <li class="rounded-sm border border-border/70 px-2 py-1 text-[10px] font-mono uppercase tracking-[0.18em] text-muted-foreground">{tag}</li>)}
					</ul>
				)}
			</header>

			<article class="article-shell rounded-lg border border-border bg-card p-6">
				<div class="content-measure prose-shell">
					<Content />
				</div>
			</article>

			{nextPost && (
				<section class="next-part-shell rounded-lg border border-border bg-card p-5 sm:p-6">
					<p class="text-xs uppercase tracking-[0.28em] text-muted-foreground">Up next · Part {String(nextPost.data.part).padStart(2, '0')}</p>
					<div class="mt-3 flex flex-wrap items-start justify-between gap-4">
						<div class="space-y-2">
							<h2 class="text-xl font-semibold text-foreground/80">{nextPost.data.title}</h2>
							<p class="max-w-3xl text-sm leading-7 text-muted-foreground">{nextPost.data.description}</p>
						</div>
						<div class="flex shrink-0 flex-col items-end gap-2 text-right">
							<span class:list={[
								'inline-flex items-center rounded-md border px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em]',
								nextPost.data.pubDate > new Date() ? 'border-border/50 text-muted-foreground' : 'border-primary/30 bg-primary/10 text-primary',
							]}>
								{nextPost.data.pubDate > new Date() ? 'Not published yet' : 'Published'}
							</span>
							<a href={`/blog/project/${post.data.projectKey}`} class="inline-flex items-center gap-1 text-sm font-semibold text-primary transition hover:underline">
								Go to series
							</a>
						</div>
					</div>
				</section>
			)}

			<footer class="flex flex-wrap items-center justify-between gap-3 border-t border-border pt-4 text-xs uppercase tracking-[0.28em] text-muted-foreground">
				<a href={`/blog/project/${post.data.projectKey}`} class="transition hover:text-primary">← Back to {post.data.projectName}</a>
				<span>Part {post.data.part} of {projectPosts.length}</span>
			</footer>
		</main>

		<script is:inline>
			(() => {
				const toggleButton = document.getElementById('theme-toggle');
				if (!toggleButton) return;

				toggleButton.addEventListener('click', () => {
					const html = document.documentElement;
					const isDark = html.classList.toggle('dark');
					localStorage.setItem('theme', isDark ? 'dark' : 'light');
				});
			})();
		</script>
	</body>
</html>

<style>
	.content-measure {
		max-width: 78ch;
	}

	.article-shell {
		position: relative;
		overflow: hidden;
	}

	.article-shell::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
		background: linear-gradient(90deg, color-mix(in oklab, var(--success) 85%, transparent), transparent 45%, color-mix(in oklab, var(--primary) 70%, transparent));
	}

	.prose-shell :global(h2) {
		margin-top: 1.75rem;
		margin-bottom: 0.8rem;
		font-size: 0.86rem;
		font-weight: 600;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--primary);
	}

	.prose-shell :global(h3) {
		margin-top: 1.25rem;
		margin-bottom: 0.6rem;
		font-size: 1.02rem;
		font-weight: 600;
		color: var(--foreground);
	}

	.prose-shell :global(p),
	.prose-shell :global(li) {
		line-height: 1.75;
		color: color-mix(in oklab, var(--foreground) 88%, var(--muted-foreground));
	}

	.prose-shell :global(ul),
	.prose-shell :global(ol) {
		padding-left: 1.25rem;
	}

	.prose-shell :global(code) {
		border: 1px solid var(--border);
		border-radius: 0.4rem;
		background: color-mix(in oklab, var(--muted) 70%, transparent);
		padding: 0.15rem 0.4rem;
		font-size: 0.85rem;
	}

	.prose-shell :global(pre) {
		overflow-x: auto;
		border: 1px solid var(--border);
		border-radius: 0.55rem;
		background: color-mix(in oklab, var(--background) 72%, black 28%);
		padding: 0.85rem 1rem;
		box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--primary) 22%, transparent);
	}

	:global(.dark) .prose-shell :global(pre) {
		background: color-mix(in oklab, var(--background) 78%, black 22%);
	}

	.prose-shell :global(pre code) {
		border: none;
		background: transparent;
		padding: 0;
	}

	.prose-shell :global(img) {
		margin-top: 1rem;
		margin-bottom: 1rem;
		max-width: 100%;
		border: 1px solid var(--border);
		border-radius: 0.75rem;
	}

	.prose-shell :global(a) {
		color: var(--primary);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.prose-shell :global(blockquote) {
		margin: 1rem 0;
		border-left: 2px solid var(--primary);
		padding-left: 0.8rem;
		color: var(--muted-foreground);
	}

	.breadcrumb-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		border: 1px solid transparent;
		padding: 0.4rem 0.7rem;
		border-radius: 999px;
		transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
	}

	.breadcrumb-chip:hover {
		color: var(--foreground);
		border-color: var(--border);
		background: color-mix(in oklab, var(--background) 70%, transparent);
	}

	.breadcrumb-chip-active {
		color: var(--foreground);
		border-color: var(--border);
		background: color-mix(in oklab, var(--background) 70%, transparent);
	}

	.next-part-shell {
		background: linear-gradient(180deg, color-mix(in oklab, var(--background) 88%, var(--card)), color-mix(in oklab, var(--background) 76%, var(--card)));
	}
</style>
