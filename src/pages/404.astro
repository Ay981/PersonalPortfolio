---
import '../../global.css';
import Analytics from '@vercel/analytics/astro';

const navItems = [
	{ label: 'Home', href: '/' },
	{ label: 'Projects', href: '/#projects' },
	{ label: 'Blog', href: '/blog' },
	{ label: 'Contact', href: '/#contact' },
];
---

<html lang="en" class="h-full">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>404 · Page Not Found</title>
		<meta name="description" content="The page you're looking for doesn't exist." />
		<Analytics />
		<script is:inline>
			(() => {
				const storedTheme = localStorage.getItem('theme');
					const shouldUseDark = storedTheme ? storedTheme === 'dark' : true;
				document.documentElement.classList.toggle('dark', shouldUseDark);
			})();
		</script>
	</head>
	<body class="h-full antialiased">
		<button id="theme-toggle" type="button" class="theme-toggle-fab" aria-label="Toggle theme">
			<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
			</svg>
			<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="4"></circle>
				<path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
			</svg>
		</button>

		<main class="flex min-h-screen w-full flex-col items-center justify-center gap-8 px-4 py-12">
			<div class="text-center space-y-4">
				<div class="text-6xl sm:text-8xl font-bold text-primary/20">404</div>
				<h1 class="text-3xl sm:text-5xl font-bold text-foreground">Page Not Found</h1>
				<p class="text-lg text-foreground/70 max-w-md">
					The page you're looking for doesn't exist. Let's get you back on track.
				</p>
			</div>

			<nav class="flex flex-col sm:flex-row gap-3">
				{
					navItems.map((item) => (
						<a
							href={item.href}
							class="rounded-lg border border-border/40 bg-foreground/5 px-5 py-3 font-medium text-foreground/70 transition-all duration-300 hover:border-border/70 hover:bg-foreground/10 active:scale-95"
						>
							{item.label}
						</a>
					))
				}
			</nav>
		</main>

		<script is:inline>
			(() => {
				const toggleButton = document.getElementById('theme-toggle');
				if (toggleButton) {
					toggleButton.addEventListener('click', () => {
						const html = document.documentElement;
						const isDark = html.classList.toggle('dark');
						localStorage.setItem('theme', isDark ? 'dark' : 'light');
					});
				}
			})();
		</script>
	</body>
</html>
