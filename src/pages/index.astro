---
import '../../global.css';
import { getCollection } from 'astro:content';
import { portfolioContent } from '../data/portfolio';

const { name, role, bio, skills, projects, email, github, linkedin, upwork } = portfolioContent;
const blogPosts = await getCollection('blog', ({ data }) => !data.draft);
const blogPostCountByProject = blogPosts.reduce(
	(accumulator, post) => {
		accumulator[post.data.projectKey] = (accumulator[post.data.projectKey] ?? 0) + 1;
		return accumulator;
	},
	{} as Record<string, number>
);

const frontendSkills = skills.filter((skill) => ['React', 'Next.js', 'TypeScript', 'Tailwind CSS', 'Astro', 'Redux Toolkit'].includes(skill));
const backendSkills = skills.filter((skill) => ['Laravel', 'Node.js', 'Supabase', 'MySQL'].includes(skill));

const sections = [
	{ id: 'hero', label: 'Home' },
	{ id: 'about', label: 'About' },
	{ id: 'projects', label: 'Projects' },
	{ id: 'blog', label: 'Blog' },
	{ id: 'skills', label: 'Skills' },
	{ id: 'contact', label: 'Contact' },
];
---

<html lang="en" class="h-full scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{name} · Portfolio</title>
		<meta name="description" content={`${name} portfolio - ${role}`} />
		<link rel="canonical" href="https://aymenabdulkerim.dev/" />
		<meta property="og:url" content="https://aymenabdulkerim.dev/" />
		<script is:inline>
			(() => {
				const storedTheme = localStorage.getItem('theme');
					const shouldUseDark = storedTheme
						? storedTheme === 'dark'
						: window.matchMedia('(prefers-color-scheme: dark)').matches;

				document.documentElement.classList.toggle('dark', shouldUseDark);
			})();
		</script>
	</head>
	<body class="h-full antialiased">
		<button id="theme-toggle" type="button" class="theme-toggle-fab" aria-label="Toggle theme">
			<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
			</svg>
			<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="4"></circle>
				<path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
			</svg>
		</button>
		<main class="flex min-h-screen w-full flex-col gap-7 py-6 sm:py-8">
			<header class="site-topbar sticky top-0 z-30 border-y-2 border-border px-4 py-3 backdrop-blur sm:px-6">
				<div class="flex flex-wrap items-center justify-between gap-3 text-sm">
					<p class="text-muted-foreground">~/home/{name.toLowerCase().replace(' ', '')}/portfolio</p>
				</div>
				<nav aria-label="Section navigation" class="mt-3 hidden border-t border-border pt-3 sm:block">
					<ul class="flex gap-2 overflow-x-auto pb-1 text-sm [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
						{
							sections.map((section) => (
								<li class="shrink-0">
									<a
										href={`#${section.id}`}
										data-nav-link
										data-section-id={section.id}
										class="block whitespace-nowrap rounded-md border-2 border-border bg-background px-3 py-1.5 transition hover:bg-muted"
									>
										{section.label}
									</a>
								</li>
							))
						}
					</ul>
				</nav>
			</header>

			<aside class="mobile-rail-shell fixed bottom-4 left-2 top-22 z-40 w-12 rounded-2xl border border-border p-1.5 backdrop-blur sm:hidden">
				<nav aria-label="Mobile section navigation" class="h-full">
					<ul class="flex h-full flex-col items-center justify-start gap-3">
						<li>
							<a href="#hero" data-nav-link data-section-id="hero" class="mobile-rail-link block h-11 w-11 rounded-xl border border-transparent p-2.5 text-muted-foreground transition hover:bg-muted" aria-label="Go to hero section">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/></svg>
								<span class="mobile-rail-tooltip">Hero</span>
							</a>
						</li>
						<li>
							<a href="#about" data-nav-link data-section-id="about" class="mobile-rail-link block h-11 w-11 rounded-xl border border-transparent p-2.5 text-muted-foreground transition hover:bg-muted" aria-label="Go to about section">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="3"/><path d="M5 20c1.7-3.2 4.1-4.8 7-4.8s5.3 1.6 7 4.8"/></svg>
								<span class="mobile-rail-tooltip">About</span>
							</a>
						</li>
						<li>
							<a href="#projects" data-nav-link data-section-id="projects" class="mobile-rail-link block h-11 w-11 rounded-xl border border-transparent p-2.5 text-muted-foreground transition hover:bg-muted" aria-label="Go to projects section">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
								<span class="mobile-rail-tooltip">Projects</span>
							</a>
						</li>
						<li>
							<a href="#blog" data-nav-link data-section-id="blog" class="mobile-rail-link block h-11 w-11 rounded-xl border border-transparent p-2.5 text-muted-foreground transition hover:bg-muted" aria-label="Go to blog section">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 19.5A2.5 2.5 0 0 1 5.5 17H20"/><path d="M5.5 17A2.5 2.5 0 0 0 3 14.5V5a2 2 0 0 1 2-2h15v14"/></svg>
								<span class="mobile-rail-tooltip">Blog</span>
							</a>
						</li>
						<li>
							<a href="#skills" data-nav-link data-section-id="skills" class="mobile-rail-link block h-11 w-11 rounded-xl border border-transparent p-2.5 text-muted-foreground transition hover:bg-muted" aria-label="Go to skills section">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 1 1.4 0l1.6 1.6a1 1 0 0 1 0 1.4l-7.8 7.8-3.1.8.8-3.1Z"/><path d="m12 8 4 4"/></svg>
								<span class="mobile-rail-tooltip">Skills</span>
							</a>
						</li>
						<li class="mt-auto">
							<a href="#contact" data-nav-link data-section-id="contact" class="mobile-rail-link block h-11 w-11 rounded-xl border border-transparent p-2.5 text-muted-foreground transition hover:bg-muted" aria-label="Go to contact section">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="6" width="18" height="12" rx="2"/><path d="m3 8 9 6 9-6"/></svg>
								<span class="mobile-rail-tooltip">Contact</span>
							</a>
						</li>
					</ul>
				</nav>
			</aside>

			<div class="mx-auto flex w-full max-w-400 flex-col gap-7 px-4 pl-17 sm:px-6 sm:pl-6">

			<section id="hero" class="mobile-section-pane scroll-mt-28 space-y-4 rounded-lg border-2 border-border bg-card p-6 relative overflow-hidden">
				<div aria-hidden="true" class="absolute -top-20 -right-20 w-40 h-40 bg-primary/5 rounded-full blur-3xl"></div>
				<div aria-hidden="true" class="absolute -bottom-10 -left-20 w-32 h-32 bg-primary/3 rounded-full blur-2xl"></div>
				<div class="relative z-10">
					<p class="text-sm text-muted-foreground"><span class="mr-2 font-bold text-success">$</span>whoami</p>
					<h1 class="text-4xl font-bold tracking-tight sm:text-6xl">
						{name}<span aria-hidden="true" class="blink-cursor text-primary">▌</span>
					</h1>
					<p class="text-sm font-semibold uppercase tracking-[0.22em] text-primary sm:text-base">
						<span class="typing-line">{role}</span>
					</p>
					<p class="max-w-3xl text-[15px] leading-6 text-foreground sm:text-base sm:leading-7">
						I build <span class="font-semibold text-primary">full-stack products</span> that feel human to use, from clean
						frontend experiences to reliable backend systems. I enjoy shipping practical software with
						<span class="font-semibold text-primary"> React</span>,
						<span class="font-semibold text-primary"> Next.js</span>,
						<span class="font-semibold text-primary"> Laravel</span>, and modern web tooling.
					</p>
					<div class="flex flex-wrap gap-3 pt-2 text-sm">
						<a
							class="rounded-md border-2 border-border px-3 py-2 hover:bg-muted"
							href={github}
							target="_blank"
						rel="noreferrer"
					>
						GitHub
					</a>
					<a
							class="rounded-md border-2 border-border px-3 py-2 hover:bg-muted"
						href={linkedin}
						target="_blank"
						rel="noreferrer"
					>
						LinkedIn
					</a>
					<a class="rounded-md border-2 border-border px-3 py-2 hover:bg-muted" href={upwork} target="_blank" rel="noreferrer">
						Upwork
					</a>
						<a class="rounded-md border-2 border-primary bg-primary px-3 py-2 font-semibold text-primary-foreground transition hover:brightness-110" href={`mailto:${email}`}>
							Email
						</a>
				</div>
					<div class="mt-4 flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-muted-foreground sm:mt-5">
						<span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-border bg-background text-[10px]">↓</span>
						<span>Scroll for projects</span>
					</div>
				</div>
			</section>

			<section id="about" class="mobile-section-pane scroll-mt-28 space-y-3 rounded-lg border-2 border-border bg-card p-6 relative">
				<div aria-hidden="true" class="absolute top-0 right-0 w-20 h-20 border-2 border-primary/20 rounded-full"></div>
				<h2 class="text-lg font-semibold uppercase tracking-[0.15em] text-primary">01 · About</h2>
				<p class="leading-7 text-muted-foreground">
					I focus on building useful software end-to-end: product UI, API design, and practical deployment workflows.
					My approach is straightforward — readable code, strong UX, and features that solve real user problems.
				</p>
			</section>

			<section id="projects" class="mobile-section-pane scroll-mt-28 space-y-4 rounded-lg border-2 border-border bg-card p-6 relative overflow-hidden">
				<div aria-hidden="true" class="absolute -top-32 left-1/2 w-64 h-64 bg-primary/5 rounded-full blur-3xl -translate-x-1/2"></div>
				<h2 class="text-lg font-semibold uppercase tracking-[0.15em] text-primary relative z-10">02 · Projects</h2>
				<div class="grid gap-4 md:grid-cols-2 relative z-10">
					{
						projects.map((project, idx) => (
							<article class="project-card group rounded-lg border-2 border-border bg-background p-4 relative overflow-hidden transition duration-300 hover:border-primary/50 hover:shadow-lg hover:shadow-primary/10" style={{ animationDelay: `${idx * 100}ms` }}>
								<div aria-hidden="true" class="absolute -right-20 -top-20 w-40 h-40 bg-primary/5 rounded-full group-hover:bg-primary/10 transition duration-300"></div>
								<div class="mb-4 overflow-hidden rounded-lg border border-border bg-muted relative">
									<img
										src={project.screenshotUrl}
										alt={`${project.title} project screenshot`}
										loading="lazy"
										decoding="async"
										class="h-64 w-full object-cover object-center sm:h-72 md:h-80 lg:h-96 transition duration-300 group-hover:scale-105"
									/>
									<div aria-hidden="true" class="absolute inset-0 bg-linear-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition duration-300"></div>
								</div>
								<div class="mb-2 flex items-center justify-between gap-3 relative z-10">
									<h3 class="font-semibold text-lg">{project.title}</h3>
									<a href={project.url} target="_blank" rel="noreferrer" class="group/link inline-flex items-center gap-1 rounded px-2 py-1 text-sm font-medium text-primary hover:bg-primary/10 transition">
										<span>View</span>
										<svg class="h-3 w-3 transition group-hover/link:translate-x-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M5 12h14M12 5l7 7-7 7"/>
										</svg>
									</a>
								</div>
								<p class="text-sm leading-6 text-foreground relative z-10">{project.description}</p>
								<ul class="mt-3 flex flex-wrap gap-2 relative z-10">
									{project.tech.map((item) => <li class="rounded-md border border-primary/30 bg-primary/5 px-2.5 py-1 text-xs font-medium text-primary">{item}</li>)}
								</ul>
								<div class="mt-4 flex items-center justify-between gap-3 border-t border-border pt-3 text-xs text-muted-foreground relative z-10">
									<span>{blogPostCountByProject[project.key] ?? 0} parts</span>
									<a href={`/blog/project/${project.key}`} class="font-medium text-primary hover:underline">
										Read devlog
									</a>
								</div>
							</article>
						))
					}
				</div>
			</section>

			<section id="blog" class="mobile-section-pane blog-section scroll-mt-28 space-y-6 rounded-lg border border-border/50 bg-card p-8 relative overflow-hidden">
				<div class="absolute top-0 left-0 h-12 w-1 rounded-full bg-linear-to-b from-primary/60 to-transparent"></div>
				<div class="flex flex-wrap items-start justify-between gap-4 border-b border-border/60 pb-5">
					<div class="space-y-2">
						<p class="text-xs uppercase tracking-[0.26em] text-muted-foreground">03 · Blog</p>
						<p class="max-w-2xl text-sm leading-7 text-foreground/75 sm:text-base">Build logs for every project — decisions, tradeoffs, and what I’d undo.</p>
					</div>
					<a href="/blog" class="blog-cta group inline-flex items-center gap-2.5 rounded-lg border border-primary/40 bg-primary/8 px-5 py-3.5 font-semibold text-primary transition-all duration-300 hover:border-primary/70 hover:bg-primary/12 active:scale-95">
						<span>Browse devlog</span>
						<svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="M5 12h14M12 5l7 7-7 7"/>
						</svg>
					</a>
				</div>
			</section>

			<section id="skills" class="mobile-section-pane scroll-mt-28 space-y-6 rounded-lg border border-border/50 bg-card p-8">
				<div class="flex flex-wrap items-start justify-between gap-4 border-b border-border/60 pb-5">
					<div>
						<p class="text-xs uppercase tracking-[0.26em] text-muted-foreground">04 · Stack</p>
						<p class="mt-2 text-sm text-foreground/60">Frontend and backend tools I use most often.</p>
					</div>
				</div>
				<div class="space-y-5">
					<div class="grid gap-3 sm:grid-cols-[7rem_1fr] sm:items-start">
						<p class="pt-1 text-xs uppercase tracking-[0.24em] text-muted-foreground">Frontend</p>
						<ul class="flex flex-wrap gap-2.5">
							{frontendSkills.map((skill, index) => (
								<li
									class="skill-badge group rounded-md border border-primary/25 bg-primary/6 px-3 py-2 text-sm font-medium text-primary/85 transition-all duration-300 hover:border-primary/50 hover:bg-primary/10 hover:scale-[1.02] cursor-default"
									style={`animation-delay: ${index * 50}ms`}
								>
									{skill}
								</li>
							))}
						</ul>
					</div>
					<div class="grid gap-3 sm:grid-cols-[7rem_1fr] sm:items-start">
						<p class="pt-1 text-xs uppercase tracking-[0.24em] text-muted-foreground">Backend</p>
						<ul class="flex flex-wrap gap-2.5">
							{backendSkills.map((skill, index) => (
								<li
									class="skill-badge group rounded-md border border-primary/25 bg-primary/6 px-3 py-2 text-sm font-medium text-primary/85 transition-all duration-300 hover:border-primary/50 hover:bg-primary/10 hover:scale-[1.02] cursor-default"
									style={`animation-delay: ${(index + frontendSkills.length) * 50}ms`}
								>
									{skill}
								</li>
							))}
						</ul>
					</div>
				</div>
			</section>

			<section id="contact" class="mobile-section-pane scroll-mt-28 space-y-8 rounded-lg border border-border/50 bg-card p-8">
				<div class="grid gap-8 lg:grid-cols-[1.3fr_0.9fr] lg:items-end">
					<div class="space-y-4">
						<p class="text-xs uppercase tracking-[0.26em] text-success">• Available for work</p>
						<h2 class="text-4xl font-semibold tracking-tight sm:text-5xl">Let's build <span class="italic text-primary">something real.</span></h2>
						<p class="max-w-2xl text-sm leading-7 text-foreground/60 sm:text-base">
							Not open to everything — open to the right thing. If the problem is interesting, reach out.
						</p>
					</div>
					<div class="flex flex-col items-start gap-4 lg:items-end">
						<a 
							class="contact-btn group inline-flex items-center gap-2.5 rounded-md border border-primary/40 bg-primary px-6 py-3.5 font-semibold text-primary-foreground transition-all duration-300 hover:brightness-110 active:scale-95"
							href={`mailto:${email}`}
						>
							<span>Send an email</span>
							<svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M5 12h14"/>
								<path d="m12 5 7 7-7 7"/>
							</svg>
						</a>
						<div class="flex flex-wrap items-center gap-5 text-xs uppercase tracking-[0.22em] text-muted-foreground">
							<a class="transition hover:text-foreground" href={github} target="_blank" rel="noreferrer">GitHub</a>
							<a class="transition hover:text-foreground" href={linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
							<a class="transition hover:text-foreground" href={upwork} target="_blank" rel="noreferrer">Upwork</a>
						</div>
					</div>
				</div>
			</section>

			<footer class="flex flex-wrap items-center justify-between gap-3 border-t border-border/60 pt-4 text-xs uppercase tracking-[0.28em] text-muted-foreground">
				<span>{name} · Full-stack developer</span>
				<span>© 2026</span>
			</footer>
			</div>
		</main>

		<script is:inline>
			(() => {
				const toggleButton = document.getElementById('theme-toggle');
				if (toggleButton) {
					toggleButton.addEventListener('click', () => {
						const html = document.documentElement;
						const isDark = html.classList.toggle('dark');
						localStorage.setItem('theme', isDark ? 'dark' : 'light');
					});
				}

				const navLinks = Array.from(document.querySelectorAll('[data-nav-link]'));
				const observedSections = Array.from(document.querySelectorAll('main section[id]')).map((sectionElement) => ({
					sectionId: sectionElement.id,
					sectionElement,
				}));

				if (navLinks.length === 0 || observedSections.length === 0) return;

				const setActiveLink = (activeId) => {
					navLinks.forEach((link) => {
						const isActive = link.getAttribute('data-section-id') === activeId;
						link.classList.toggle('bg-muted', isActive);
						link.classList.toggle('text-primary', isActive);
						link.setAttribute('aria-current', isActive ? 'page' : 'false');
					});

					const activeIndex = observedSections.findIndex((entry) => entry.sectionId === activeId);
					if (activeIndex === -1) return;

					observedSections.forEach((entry, index) => {
						entry.sectionElement.classList.toggle('section-dimmed', index < activeIndex);
					});
				};

				const observer = new IntersectionObserver(
					(entries) => {
						const visibleEntries = entries
							.filter((entry) => entry.isIntersecting)
							.sort((entryA, entryB) => entryB.intersectionRatio - entryA.intersectionRatio);

						if (visibleEntries.length === 0) return;
						setActiveLink(visibleEntries[0].target.id);
					},
					{
						rootMargin: '-25% 0px -65% 0px',
						threshold: [0],
					}
				);

				observedSections.forEach(({ sectionElement }) => observer.observe(sectionElement));
				setActiveLink(observedSections[0].sectionId);
			})();
		</script>

		<style>
			.blink-cursor {
				animation: blink-caret 1.1s steps(1, end) infinite;
			}

			.typing-line {
				display: inline-block;
				max-width: 0;
				overflow: hidden;
				white-space: nowrap;
				animation: typing 2.2s steps(20, end) 0.2s forwards;
			}

			@keyframes blink-caret {
				0%,
				49% {
					opacity: 1;
				}
				50%,
				100% {
					opacity: 0;
				}
			}

			@keyframes typing {
				from {
					max-width: 0;
				}
				to {
					max-width: 24ch;
				}
			}
		</style>
	</body>
</html>
