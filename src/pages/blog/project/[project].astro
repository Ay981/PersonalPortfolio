---
import '../../../../global.css';
import { getCollection, type CollectionEntry } from 'astro:content';
import { portfolioContent } from '../../../data/portfolio';
import Analytics from '@vercel/analytics/astro';

export async function getStaticPaths() {
	return portfolioContent.projects.map((projectItem) => ({
		params: { project: projectItem.key },
	}));
}

const projectKey = Astro.params.project ?? '';
const project = portfolioContent.projects.find((item) => item.key === projectKey);
const now = new Date();

let projectPosts: CollectionEntry<'blog'>[] = [];
try {
	projectPosts = (await getCollection('blog', ({ data }) => data.projectKey === projectKey)).sort(
		(a, b) => a.data.part - b.data.part
	);
} catch {
	projectPosts = [];
}

const partsTotal = projectPosts.length;

if (!project) {
	return Astro.redirect('/blog');
}
---

<html lang="en" class="h-full scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>{project.title} · Devlog</title>
		<meta name="description" content={`All devlog entries for ${project.title}.`} />
		<link rel="canonical" href={`https://aymenabdulkerim.dev/blog/project/${project.key}/`} />
		<meta property="og:url" content={`https://aymenabdulkerim.dev/blog/project/${project.key}/`} />
		<Analytics />
		<script is:inline>
			(() => {
				const storedTheme = localStorage.getItem('theme');
					const shouldUseDark = storedTheme ? storedTheme === 'dark' : true;
				document.documentElement.classList.toggle('dark', shouldUseDark);
			})();
		</script>
	</head>
	<body class="blog-copy min-h-screen bg-background text-foreground antialiased">
		<button id="theme-toggle" type="button" class="theme-toggle-fab" aria-label="Toggle theme">
			<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
			</svg>
			<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="4"></circle>
				<path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
			</svg>
		</button>
		<nav class="site-topbar scroll-chrome scroll-chrome-nav w-full border-y border-border px-5 py-2 text-sm sm:px-8">
			<div class="nav-inner flex w-full flex-nowrap items-center justify-between gap-3 overflow-x-auto [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
				<div class="flex shrink-0 items-center gap-2">
					<a href="/" class="breadcrumb-chip"><span class="sm:hidden">~</span><span class="hidden sm:inline">Portfolio</span></a>
					<span class="text-muted-foreground/40">/</span>
					<a href="/blog" class="breadcrumb-chip"><span class="sm:hidden">posts</span><span class="hidden sm:inline">All posts</span></a>
					<span class="text-muted-foreground/40">/</span>
					<span class="breadcrumb-chip breadcrumb-chip-active"><span class="sm:hidden">../{project.key}</span><span class="hidden sm:inline">{project.title}</span></span>
				</div>
				<p class="font-mono hidden shrink-0 rounded-md border border-border bg-card px-3 py-2 text-xs text-muted-foreground sm:block">~/blog/project/{project.key}</p>
			</div>
		</nav>
		<main class="page-wrapper">
			<section class="project-layout-shell">
				<aside class="project-sidebar-spacer" aria-hidden="true"></aside>
				<div class="project-main-stack">
			<header class="project-feed-shell rounded-2xl border border-border p-6 sm:p-8">
				<div class="flex flex-wrap items-start justify-between gap-4">
					<div class="space-y-4">
						<div class="space-y-2">
							<h1 class="text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">{project.title}</h1>
							<p class="max-w-3xl text-sm leading-7 text-muted-foreground sm:text-base">{project.description}</p>
						</div>
					</div>
					
				</div>
				<div class="mt-6 h-px bg-border/70"></div>
			</header>

			<section class="space-y-4">
				{projectPosts.map((post, index) => {
					const isFuture = post.data.draft || post.data.pubDate > now;
					const isLatest = index === 0;
					const cardClasses = [
						'project-feed-card block w-full rounded-2xl border p-5 text-left sm:p-6 transition duration-300',
						isFuture
							? 'project-feed-future border-border/50 bg-background/35 opacity-45'
							: 'border-border bg-card shadow-sm shadow-black/5 dark:shadow-none hover:-translate-y-[1px] hover:border-primary/35 hover:shadow-primary/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40',
					].join(' ');

					return isFuture ? (
						<article class={cardClasses}>
							<div class="mb-4 flex flex-wrap items-start justify-between gap-3">
								<div class="space-y-1">
									<p class="text-xs uppercase tracking-[0.28em] text-muted-foreground">Part {String(post.data.part).padStart(2, '0')}</p>
									<h2 class:list={['text-xl sm:text-2xl font-semibold tracking-tight', isFuture ? 'text-foreground/75' : 'text-foreground']}>
										{post.data.title}
									</h2>
									<p class:list={['max-w-3xl text-sm sm:text-base leading-7', isFuture ? 'text-muted-foreground/70' : 'text-muted-foreground']}>
										{post.data.description}
									</p>
								</div>
								<div class="flex shrink-0 flex-col items-end gap-2 text-right">
									<span class:list={[
										'inline-flex items-center rounded-md border px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em]',
										isFuture ? 'border-border/50 text-muted-foreground' : isLatest ? 'border-success/40 bg-success/10 text-success' : 'border-primary/30 bg-primary/10 text-primary',
									]}>
										{isFuture ? 'Future' : isLatest ? 'Live' : 'Published'}
									</span>
									{!isFuture && (
										<p class="text-xs uppercase tracking-[0.22em] text-muted-foreground">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</p>
									)}
								</div>
							</div>
							<div class="h-px bg-border/70"></div>
							<div class="mt-4 flex items-center justify-between gap-3 text-sm">
								<p class="text-muted-foreground">Part {post.data.part}</p>
								<span class="font-semibold text-muted-foreground">Future entry</span>
							</div>
						</article>
					) : (
						<a class={cardClasses} href={`/blog/post/${post.id}`} aria-label={`Read ${post.data.title}`}>
							<div class="mb-4 flex flex-wrap items-start justify-between gap-3">
								<div class="space-y-1">
									<p class="text-xs uppercase tracking-[0.28em] text-muted-foreground">Part {String(post.data.part).padStart(2, '0')}</p>
									<h2 class:list={['text-xl sm:text-2xl font-semibold tracking-tight', isFuture ? 'text-foreground/75' : 'text-foreground']}>
										{post.data.title}
									</h2>
									<p class:list={['max-w-3xl text-sm sm:text-base leading-7', isFuture ? 'text-muted-foreground/70' : 'text-muted-foreground']}>
										{post.data.description}
									</p>
								</div>
								<div class="flex shrink-0 flex-col items-end gap-2 text-right">
									<span class:list={[
										'inline-flex items-center rounded-md border px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em]',
										isFuture ? 'border-border/50 text-muted-foreground' : isLatest ? 'border-success/40 bg-success/10 text-success' : 'border-primary/30 bg-primary/10 text-primary',
									]}>
										{isFuture ? 'Future' : isLatest ? 'Live' : 'Published'}
									</span>
									{!isFuture && (
										<p class="text-xs uppercase tracking-[0.22em] text-muted-foreground">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</p>
									)}
								</div>
							</div>
							<div class="h-px bg-border/70"></div>
							<div class="mt-4 flex items-center justify-between gap-3 text-sm">
								<p class="text-muted-foreground">Part {post.data.part}</p>
								<span class="inline-flex items-center gap-1 font-semibold text-primary">
									Read part {post.data.part}
								</span>
							</div>
						</a>
					);
				})}
			</section>
				</div>
			</section>
		</main>

		<script is:inline>
			(() => {
				const toggleButton = document.getElementById('theme-toggle');
				if (!toggleButton) return;

				toggleButton.addEventListener('click', () => {
					const html = document.documentElement;
					const isDark = html.classList.toggle('dark');
					localStorage.setItem('theme', isDark ? 'dark' : 'light');
				});

				let previousY = window.scrollY;
				let rafId = 0;
				const hiddenClass = 'chrome-hidden';

				const updateChromeVisibility = () => {
					rafId = 0;
					const currentY = window.scrollY;
					const delta = currentY - previousY;

					if (currentY <= 72) {
						document.body.classList.remove(hiddenClass);
					} else if (delta > 6) {
						document.body.classList.add(hiddenClass);
					} else if (delta < -6) {
						document.body.classList.remove(hiddenClass);
					}

					previousY = currentY;
				};

				window.addEventListener(
					'scroll',
					() => {
						if (rafId) return;
						rafId = window.requestAnimationFrame(updateChromeVisibility);
					},
					{ passive: true }
				);
			})();
		</script>
	</body>
</html>

<style>
	:root {
		--page-max: 1400px;
		--side-col: 220px;
	}

	.nav-inner {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 48px;
	}

	.scroll-chrome {
		transition: transform 220ms ease, opacity 220ms ease;
		will-change: transform, opacity;
	}

	.scroll-chrome-nav {
		position: sticky;
		top: 0;
		z-index: 45;
		background: color-mix(in oklab, var(--background) 92%, transparent);
		backdrop-filter: blur(6px);
	}

	body.chrome-hidden .scroll-chrome-nav {
		transform: translateY(calc(-100% - 2px));
	}

	.page-wrapper {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 48px;
	}

	.project-layout-shell {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
	}

	.project-sidebar-spacer {
		display: none;
	}

	.project-main-stack {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding: 40px 0 80px;
	}

	.project-feed-shell {
		position: relative;
		overflow: hidden;
		background:
			radial-gradient(circle at top right, color-mix(in oklab, var(--primary) 10%, transparent), transparent 38%),
			color-mix(in oklab, var(--background) 84%, var(--card));
	}

	.project-feed-shell::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background-image: radial-gradient(circle at 1px 1px, color-mix(in oklab, var(--foreground) 9%, transparent) 1px, transparent 0);
		background-size: 22px 22px;
		opacity: 0.35;
	}

	.project-feed-shell > * {
		position: relative;
		z-index: 1;
	}

	.project-feed-card {
		position: relative;
		overflow: hidden;
	}

	.project-feed-card::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: linear-gradient(180deg, color-mix(in oklab, var(--primary) 5%, transparent), transparent 30%);
		opacity: 0;
		transition: opacity 0.25s ease;
	}

	.project-feed-card:hover::before {
		opacity: 1;
	}

	.project-feed-future {
		border-style: dashed;
	}

	.breadcrumb-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		border: 1px solid transparent;
		padding: 0.4rem 0.7rem;
		border-radius: 999px;
		transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
	}

	.breadcrumb-chip:hover {
		color: var(--foreground);
		border-color: var(--border);
		background: color-mix(in oklab, var(--background) 70%, transparent);
	}

	.breadcrumb-chip-active {
		color: var(--foreground);
		border-color: var(--border);
		background: color-mix(in oklab, var(--background) 70%, transparent);
	}

	@media (min-width: 1280px) {
		.project-layout-shell {
			grid-template-columns: var(--side-col) minmax(0, 1fr);
		}

		.project-sidebar-spacer {
			display: block;
			border-right: 1px solid var(--border);
			min-height: calc(100vh - 56px);
		}

		.project-main-stack {
			padding: 64px 0 120px 32px;
		}
	}

	@media (max-width: 800px) {
		.nav-inner {
			padding: 0 24px;
		}

		.page-wrapper {
			padding: 0 24px;
		}

		.project-main-stack {
			padding: 40px 0 80px;
		}
	}
</style>
